{
  "name": "Live Translation",
  "description": "Live translation app for smart glasses.",
  "version": "1.0.0",
  "settings": [
    {
      "type": "group",
      "title": "Language settings"
    },
    {
      "key": "transcribe_language",
      "type": "select_with_search",
      "label": "Transcribe language",
      "defaultValue": "Chinese (Mandarin)",
      "options": [
        { "label": "English", "value": "English" },
        { "label": "Chinese (Cantonese, Simplified)", "value": "Chinese (Cantonese, Simplified)" },
        { "label": "Chinese (Hanzi)", "value": "Chinese (Hanzi)" },
        { "label": "Chinese (Pinyin)", "value": "Chinese (Pinyin)" },
        { "label": "Spanish", "value": "Spanish" },
        { "label": "French", "value": "French" },
        { "label": "German", "value": "German" },
        { "label": "Italian", "value": "Italian" },
        { "label": "Japanese", "value": "Japanese" },
        { "label": "Korean", "value": "Korean" },
        { "label": "Russian", "value": "Russian" }
      ]
    },
    {
      "key": "translate_language",
      "type": "select_with_search",
      "label": "Translate to",
      "defaultValue": "English",
      "options": [
        { "label": "English", "value": "English" },
        { "label": "Chinese (Cantonese, Simplified)", "value": "Chinese (Cantonese, Simplified)" },
        { "label": "Chinese (Hanzi)", "value": "Chinese (Hanzi)" },
        { "label": "Chinese (Pinyin)", "value": "Chinese (Pinyin)" },
        { "label": "Spanish", "value": "Spanish" },
        { "label": "French", "value": "French" },
        { "label": "German", "value": "German" },
        { "label": "Italian", "value": "Italian" },
        { "label": "Japanese", "value": "Japanese" },
        { "label": "Korean", "value": "Korean" },
        { "label": "Russian", "value": "Russian" }
      ]
    },
    {
      "type": "group",
      "title": "Layout settings"
    },
    {
      "key": "line_width",
      "type": "select",
      "label": "Line width",
      "defaultValue": "Medium",
      "options": [
        { "label": "Very Narrow", "value": "Very Narrow" },
        { "label": "Narrow", "value": "Narrow" },
        { "label": "Medium", "value": "Medium" },
        { "label": "Wide", "value": "Wide" }
      ]
    },
    {
      "key": "number_of_lines",
      "type": "select",
      "label": "Number of lines",
      "defaultValue": 3,
      "options": [
        { "label": "2", "value": 2 },
        { "label": "3", "value": 3 },
        { "label": "4", "value": 4 },
        { "label": "5", "value": 5 }
      ]
    },
    {
      "key": "display_mode",
      "type": "select",
      "label": "When to display",
      "defaultValue": "translations",
      "options": [
        { "label": "Only show translations", "value": "translations" },
        { "label": "Caption everything", "value": "everything" }
      ]
    },
    {
      "key": "confidence_heuristic",
      "type": "select",
      "label": "Interim Confidence Heuristic",
      "defaultValue": "None",
      "options": [
        { "label": "None", "value": "None" },
        { "label": "Word Stability", "value": "WordStability" },
        { "label": "Prefix Retention", "value": "PrefixRetention" },
        { "label": "Edit Distance", "value": "EditDistance" },
        { "label": "Word Duration", "value": "WordDuration" },
        { "label": "Trailing Word Decay", "value": "TrailingWordDecay" },
        { "label": "Hybrid", "value": "Hybrid" }
      ]
    }
  ]
}